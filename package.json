{
  "name": "jcms",
  "version": "0.1.20260622a",
  "description": "JCMS — Judicial Case Management System (Docker / VPS deployment)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "sync:class-years": "node scripts/sync-class-years-from-roster.js",
    "sync:html-version": "node scripts/sync-jcms-html-version.js",
    "version:bump": "node scripts/bump-jcms-version.js",
    "repair:dynamics-fts": "node scripts/repair-dynamics-fts.js",
    "db:prune-cases-obsolete": "node scripts/pruneCasesObsoleteColumns.js",
    "test:inheritance": "node scripts/test-inheritance-fixtures.mjs",
    "gen:police-geojson": "node scripts/fetch-police-address-data.js && node scripts/convert-police-geojson.js",
    "gen:judicial-geojson": "node scripts/fetch-moj-agency-addresses.js && node scripts/convert-judicial-geojson.js",
    "gen:taipei-urban-plan-geojson": "node scripts/convert-taipei-urban-plan-geojson.js",
    "gen:ntpc-urban-plan-geojson": "node scripts/convert-ntpc-urban-plan-geojson.js",
    "gen:urban-plan-geojson": "node scripts/convert-taipei-urban-plan-geojson.js && node scripts/convert-ntpc-urban-plan-geojson.js",
    "gen:taipei-police-geojson": "npm run gen:police-geojson"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "ISC",
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "multer": "^1.4.5-lts.1",
    "pngjs": "^7.0.0",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@turf/helpers": "^7.2.0",
    "@turf/simplify": "^7.2.0",
    "proj4": "^2.15.0",
    "shapefile": "^0.6.6"
  }
}
