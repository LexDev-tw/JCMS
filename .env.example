PORT=3000
DB_PATH=/app/data/app.db

# 對外網址（HTTPS，不含尾隨斜線）；Google OAuth 與絕對連結會用到
# JCMS_PUBLIC_URL=https://jcms.example.com

# docker compose 對外埠（預設 3000）；使用 tls profile 時可改為僅內部 3000
# JCMS_PUBLISH_PORT=3000

# 使用 docker compose --profile tls up 時必填
# JCMS_DOMAIN=jcms.example.com

# Google Calendar（唯讀 OAuth；亦可於總覽週曆 ⚙ 面板內設定，系統設定優先於此）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://jcms.example.com/api/google-calendar/oauth/callback
# GOOGLE_TOKEN_ENC_KEY=

# 中央氣象署開放資料（後端 proxy，勿放前端）
# CWA_API_KEY=

# 環境部空氣品質（48269 測站 + 28178 小時值；後端 proxy）
# MOENV_API_KEY=
