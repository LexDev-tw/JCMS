PORT=3000
DB_PATH=./data/app.db

# Google Calendar（唯讀 OAuth；亦可於總覽週曆 ⚙ 面板內設定，系統設定優先於此）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/google-calendar/oauth/callback
# GOOGLE_TOKEN_ENC_KEY=

# 中央氣象署開放資料（後端 proxy，勿放前端）
# CWA_API_KEY=

# 環境部空氣品質（48269 測站 + 28178 小時值；後端 proxy）
# MOENV_API_KEY=
